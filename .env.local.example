NEXT_PUBLIC_WHATSAPP=919999999999

# Supabase — public keys (safe to ship to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY

# Supabase — SERVICE ROLE key (SERVER ONLY, never commit!)
# Needed by the /dashboard page to read signups + analytics.
# Get it from: Supabase → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE

# =============================================================================
# Dashboard authentication — MUST be set in production or logins break closed.
# =============================================================================
#
# 1. ADMIN_PASSWORD_HASH — bcrypt hash of the owner password (cost 12).
#    Generate locally:
#      node -e "console.log(require('bcryptjs').hashSync('YOUR_STRONG_PASSWORD', 12))"
#    Never commit the plaintext anywhere. The hash is safe to store in env vars.
ADMIN_PASSWORD_HASH=PASTE_BCRYPT_HASH_HERE
#
# 2. ADMIN_SESSION_SECRET — random 64-char hex for HMAC-signing session cookies.
#    Generate with: openssl rand -hex 32
#    If lost, regenerate — it only invalidates existing sessions.
ADMIN_SESSION_SECRET=PASTE_64_CHAR_HEX_SECRET_HERE
